<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="plugin.video.deccandelight" version="2.1.0" name="Indian Movie Hub" provider-name="gujal">
<requires>
	<import addon="xbmc.python" version="3.0.0" />
	<import addon="script.module.six" />
	<import addon="script.module.kodi-six" />
	<import addon="script.module.beautifulsoup4" version="4.0.0"/>
	<import addon="script.module.html5lib" />
	<import addon="script.module.resolveurl" version="5.1.0"/>
	<import addon="plugin.video.youtube" optional="true" />
	<import addon="plugin.video.imdb.trailers" optional="true" />
</requires>
<extension point="xbmc.python.pluginsource" library="main.py">
  	<provides>video</provides>
</extension>
<extension point="xbmc.addon.metadata">
	<summary>Movies and shows in Indian languages</summary>
	<description>This addon provides access to entertainment in various Indian languages such as Tamil, Telugu, Malayalam, Kannada, and Hindi[CR]Indian Movie Hub is and always will be free and open-source. None of its code and resources may be sold or redistributed for any commercial purposes.[CR]Indian Movie Hub and its developers [B]DO NOT[/B] host, create, or distribute any of the content displayed in the addon, it simply scrapes ad financed public websites.[CR]Based on Deccan Delight by gujal (GPL-3.0).</description>
	<platform>all</platform>
	<website>https://github.com/Anshul-001/AnshulKodiRepo</website>
	<disclaimer>Indian Movie Hub and its developers are not in any way affiliated with Kodi or any of the sites used in the addon.</disclaimer>
	<assets>
		<icon>icon.png</icon>
		<fanart>fanart.jpg</fanart>
		<screenshot>resources/images/screenshot-01.jpg</screenshot>
		<screenshot>resources/images/screenshot-02.jpg</screenshot>
		<screenshot>resources/images/screenshot-03.jpg</screenshot>
	</assets>
	<reuselanguageinvoker>false</reuselanguageinvoker>
</extension>
</addon>
<addon id="repository.anshul" name="Anshul Kodi Repo" version="1.0.1" provider-name="anshul">
	<extension point="xbmc.addon.repository" name="Anshul Kodi Repo">
		<dir>
			<info compressed="false">https://raw.githubusercontent.com/Anshul-001/AnshulKodiRepo/master/addons.xml</info>
			<checksum>https://raw.githubusercontent.com/Anshul-001/AnshulKodiRepo/master/addons.xml.md5</checksum>
			<datadir zip="true">https://raw.githubusercontent.com/Anshul-001/AnshulKodiRepo/master/zips/</datadir>
		</dir>
		<dir>
			<info compressed="false">https://raw.githubusercontent.com/Gujal00/smrzips/master/addons.xml</info>
			<checksum>https://raw.githubusercontent.com/Gujal00/smrzips/master/addons.xml.md5</checksum>
			<datadir zip="true">https://raw.githubusercontent.com/Gujal00/smrzips/master/zips/</datadir>
		</dir>
	</extension>
	<extension point="xbmc.addon.metadata">
		<summary>Anshul Kodi Repo</summary>
		<description>Personal Kodi addon repository. Includes a maintained fork of Deccan Delight and mirrors ResolveURL from the SMR repository.</description>
		<platform>all</platform>
		<assets>
			<icon>icon.png</icon>
			<fanart>fanart.jpg</fanart>
		</assets>
	</extension>
</addon>
</addons>
